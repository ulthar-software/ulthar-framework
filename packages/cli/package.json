{
    "name": "@ulthar/cli",
    "packageManager": "yarn@3.3.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "bin": "bin/cli.mjs",
    "devDependencies": {
        "@types/jest": "^29.5.1",
        "@types/node": "^20.1.0",
        "esbuild": "^0.17.18",
        "jest": "^29.5.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.4"
    },
    "scripts": {
        "build": "tsc -p tsconfig.lib.json && yarn bundle",
        "bundle": "esbuild dist/index.js --bundle --platform=node --format=esm --outfile=bin/cli.mjs",
        "test": "jest"
    },
    "dependencies": {
        "@ulthar/blamey": "workspace:^",
        "@ulthar/commandy": "workspace:^",
        "@ulthar/filey": "workspace:^",
        "@ulthar/shelly": "workspace:^"
    }
}
